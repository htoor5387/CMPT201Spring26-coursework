#include <stdio.h>
#include <stdlib.h>
#include <sys/types.h>
#include <unistd.h>

int main() {

  int pid = fork();
  if (pid == -1) {
    perror("fail");
    exit(EXIT_FAILURE);
  } // fork fail
  
  char *args[] = {"ls", "-a"};
  for (int i = 0; i < 5; i++) {
    if (pid > 0) {
      execvp(args[0], args);
    } // parent
    else {
      execlp("ls", "ls", "-alh");
    } // child
  }

  return 0;
}
