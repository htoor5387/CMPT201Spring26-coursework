#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <string.h>

int main() {
  
  //char array to print
  char *msg = "Hello world!\n";
  int i = 0;
  while (i < strlen(msg)){
  
    printf("%c", msg[i++]);
    printf("sleeping 3s\n");
    sleep(3);
  }
  // printf("DONE");
  return 0;
}
