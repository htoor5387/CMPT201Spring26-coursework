#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
int main() {

  // pid_t pid=fork() to get PID

  int pid = fork();
  fork();
  fork();
  fork();
  fork();
  if (pid > 0) {
    sleep(5);
    printf("still waiting");
    sleep(2);
    exit(1);
  } // parent
  else {
    printf("child id: %d\n", getppid());
  } // for all child proc
}
